<ui:FluentWindow x:Class="Macrofy.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:Macrofy.App"
        mc:Ignorable="d"
        Title="Macrofy"
        Height="780" Width="1160" MinHeight="660" MinWidth="1020"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="None"
        Background="{StaticResource RmWindowBrush}">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:EmptyToVisibilityConverter x:Key="EmptyToVis" />
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
        <local:ActionKindToLabelConverter x:Key="ActionKindLabel" />

        <!-- One key on the visual keyboard -->
        <DataTemplate x:Key="KeyCapTemplate">
            <Border Width="{Binding Width}" Height="30" Background="Transparent">
                <Border x:Name="cap" Margin="1.5" CornerRadius="5"
                        Background="{StaticResource RmCardBrush}"
                        BorderBrush="{StaticResource RmCardBorderBrush}" BorderThickness="1">
                    <TextBlock x:Name="lbl" Text="{Binding Label}" FontSize="10" Margin="2,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                </Border>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSpacer}" Value="True">
                    <Setter TargetName="cap" Property="Background" Value="Transparent" />
                    <Setter TargetName="cap" Property="BorderThickness" Value="0" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Capturable}" Value="False">
                    <Setter TargetName="cap" Property="Opacity" Value="0.4" />
                    <Setter TargetName="cap" Property="ToolTip"
                            Value="Windows handles this key before Macrofy sees it — it can't be captured or turned into a macro." />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsPressed}" Value="True">
                    <Setter TargetName="cap" Property="Background" Value="{StaticResource RmAccentBrush}" />
                    <Setter TargetName="cap" Property="BorderBrush" Value="{StaticResource RmAccentBrush}" />
                    <Setter TargetName="lbl" Property="Foreground" Value="#06201C" />
                    <Setter TargetName="lbl" Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- One keyboard row -->
        <DataTemplate x:Key="KeyRowTemplate">
            <ItemsControl ItemsSource="{Binding}" ItemTemplate="{StaticResource KeyCapTemplate}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </DataTemplate>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Macrofy" />

        <!-- Body: sidebar panel + content panel -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="232" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR PANEL -->
            <Border Grid.Column="0" Background="{StaticResource RmSidebarBrush}"
                    CornerRadius="12" Margin="8,0,4,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="18,18,18,20">
                        <Border Width="36" Height="36" CornerRadius="9" Background="{StaticResource RmAccentBrush}">
                            <ui:SymbolIcon Symbol="Keyboard24" FontSize="20" Foreground="#06201C"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Macrofy" FontSize="16" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>

                    <TextBlock DockPanel.Dock="Bottom" Margin="22,0,0,16" FontSize="11"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               Text="v0.1" />

                    <StackPanel>
                        <RadioButton x:Name="NavDevices" GroupName="Nav" Style="{StaticResource NavItemStyle}"
                                     IsChecked="True">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Keyboard24" FontSize="18" />
                                <TextBlock Text="Devices" Margin="12,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavAbout" GroupName="Nav" Style="{StaticResource NavItemStyle}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Info24" FontSize="18" />
                                <TextBlock Text="About" Margin="12,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- CONTENT PANEL -->
            <Border Grid.Column="1" Background="{StaticResource RmPanelBrush}"
                    CornerRadius="12" Margin="4,0,8,0">
                <Grid>

                    <!-- DEVICES VIEW -->
                    <Grid Margin="28,22,28,22"
                          Visibility="{Binding IsChecked, ElementName=NavDevices, Converter={StaticResource BoolToVis}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Devices" FontSize="26" FontWeight="Bold" />
                                <TextBlock Margin="0,2,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Text="Pick a keyboard, toggle capture, then press its keys to test isolation." />
                            </StackPanel>
                            <ui:Button x:Name="RefreshButton" Click="RefreshButton_Click"
                                       HorizontalAlignment="Right" VerticalAlignment="Top"
                                       Icon="{ui:SymbolIcon ArrowSync24}" Content="Refresh" />
                        </Grid>

                        <!-- Device list + capture card -->
                        <Grid Grid.Row="1" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="340" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <DockPanel Grid.Column="0">
                                <TextBlock DockPanel.Dock="Top" Text="DETECTED KEYBOARDS" FontSize="11"
                                           FontWeight="SemiBold" Margin="2,0,0,8"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                <ui:ToggleSwitch DockPanel.Dock="Top" Content="Show non-keyboard devices"
                                                 FontSize="12" Margin="0,0,0,10"
                                                 IsChecked="{Binding ShowAllDevices, Mode=TwoWay}" />
                                <Grid>
                                    <ListBox ItemsSource="{Binding Keyboards}"
                                             SelectedItem="{Binding SelectedKeyboard, Mode=TwoWay}"
                                             ItemContainerStyle="{StaticResource DeviceCardStyle}"
                                             Background="Transparent" BorderThickness="0" MaxHeight="220"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="9"
                                                            Background="#1FFFFFFF" Margin="0,0,12,0">
                                                        <ui:SymbolIcon Symbol="Keyboard24" FontSize="20"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                            <TextBlock FontSize="11"
                                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                       Text="{Binding CollectionCount, StringFormat='{}{0} HID collection(s)'}" />
                                                            <Border Margin="8,0,0,0" CornerRadius="4" Padding="5,1"
                                                                    Background="#33FF6B6B"
                                                                    Visibility="{Binding IsLikelyKeyboard, Converter={StaticResource InverseBoolToVis}}">
                                                                <TextBlock Text="not a keyboard" FontSize="10" Foreground="#FFC2C2" />
                                                            </Border>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <TextBlock VerticalAlignment="Top" Margin="2,4,0,0"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding Keyboards.Count, Converter={StaticResource EmptyToVis}}"
                                               Text="No keyboards detected. Plug one in and hit Refresh." />
                                </Grid>
                            </DockPanel>

                            <Grid Grid.Column="2" VerticalAlignment="Top">
                                <ui:Card Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <TextBlock Text="{Binding SelectedKeyboard.DisplayName}"
                                                       FontSize="18" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding StatusText}" Margin="0,6,0,0" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                                <ui:TextBox PlaceholderText="Rename this keyboard…" Width="240"
                                                            Text="{Binding RenameText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <ui:Button Content="Save name" Margin="8,0,0,0"
                                                           Click="RenameButton_Click" />
                                            </StackPanel>
                                        </StackPanel>
                                        <ui:ToggleSwitch Grid.Column="1" VerticalAlignment="Center"
                                                         Focusable="False"
                                                         IsChecked="{Binding IsCapturing, Mode=TwoWay}"
                                                         IsEnabled="{Binding HasSelection}" Content="Capture" />
                                    </Grid>
                                </ui:Card>
                                <StackPanel Visibility="{Binding HasSelection, Converter={StaticResource InverseBoolToVis}}"
                                            VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,24,0,0">
                                    <ui:SymbolIcon Symbol="CursorClick24" FontSize="28" HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                    <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Text="Select a keyboard on the left." />
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <!-- Keyboard tester (left, prominent) + live key bar (right) -->
                        <Grid Grid.Row="2" Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="360" />
                            </Grid.ColumnDefinitions>

                            <!-- TEST -->
                            <Border Grid.Column="0" Background="{StaticResource RmCardBrush}"
                                    BorderBrush="{StaticResource RmCardBorderBrush}" BorderThickness="1"
                                    CornerRadius="12" Padding="20,16">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Top"
                                               Text="TEST — keys light up as you press them on the captured device"
                                               FontSize="11" FontWeight="SemiBold" Margin="2,0,0,12"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                    <Viewbox Stretch="Uniform" StretchDirection="Both"
                                             HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <ItemsControl ItemsSource="{Binding KeyboardLayout.Rows}"
                                                      ItemTemplate="{StaticResource KeyRowTemplate}" />
                                    </Viewbox>
                                </DockPanel>
                            </Border>

                            <!-- MACROS: bind captured keys to actions -->
                            <Border Grid.Column="2" Background="{StaticResource RmCardBrush}"
                                    BorderBrush="{StaticResource RmCardBorderBrush}" BorderThickness="1"
                                    CornerRadius="12">
                                <DockPanel Margin="16,14,16,14">
                                    <TextBlock DockPanel.Dock="Top" Text="MACROS" FontSize="11" FontWeight="SemiBold"
                                               Margin="0,0,0,10"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />

                                    <!-- LAYERS: pick which layer you're editing; + / – manage them -->
                                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                                        <Grid Margin="0,0,0,6">
                                            <TextBlock Text="LAYERS" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                            <Border HorizontalAlignment="Right" CornerRadius="4" Padding="6,1"
                                                    Background="{StaticResource RmAccentMutedBrush}"
                                                    Visibility="{Binding IsCapturing, Converter={StaticResource BoolToVis}}">
                                                <TextBlock FontSize="10" Foreground="{StaticResource RmAccentBrush}"
                                                           Text="{Binding ActiveLayerName, StringFormat='active: {0}'}" />
                                            </Border>
                                        </Grid>
                                        <DockPanel>
                                            <ui:Button DockPanel.Dock="Right" Content="–" Padding="10,4" Margin="6,0,0,0"
                                                       ToolTip="Remove the selected layer"
                                                       Click="RemoveLayerButton_Click" IsEnabled="{Binding CanRemoveLayer}" />
                                            <ui:Button DockPanel.Dock="Right" Content="+" Padding="10,4" Margin="6,0,0,0"
                                                       ToolTip="Add a new layer" Click="AddLayerButton_Click" />
                                            <ListBox ItemsSource="{Binding Layers}"
                                                     SelectedItem="{Binding SelectedLayer, Mode=TwoWay}"
                                                     ItemContainerStyle="{StaticResource LayerChipStyle}"
                                                     Background="Transparent" BorderThickness="0"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                <ListBox.ItemsPanel>
                                                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                                </ListBox.ItemsPanel>
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate><TextBlock Text="{Binding Name}" FontSize="12" /></DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </DockPanel>
                                    </StackPanel>

                                    <!-- Add-binding form -->
                                    <Border DockPanel.Dock="Top" CornerRadius="8" Padding="12" Margin="0,0,0,12"
                                            Background="#14FFFFFF">
                                        <StackPanel>
                                            <!-- STEP 1: pick a key -->
                                            <TextBlock Text="STEP 1 — PICK A KEY" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                            <TextBlock Margin="0,3,0,0" FontSize="12" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Text="Press a key on the captured keyboard — it'll show up below."
                                                       Visibility="{Binding HasBindKey, Converter={StaticResource InverseBoolToVis}}" />
                                            <Border Margin="0,6,0,0" CornerRadius="6" Padding="10,6"
                                                    Background="{StaticResource RmAccentBrush}"
                                                    HorizontalAlignment="Left"
                                                    Visibility="{Binding HasBindKey, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Foreground="#06201C" FontWeight="SemiBold"
                                                           Text="{Binding BindKeyName, StringFormat='Selected key:  {0}'}" />
                                            </Border>

                                            <!-- STEP 2: choose what it does -->
                                            <TextBlock Text="STEP 2 — CHOOSE WHAT IT DOES" FontSize="10" FontWeight="SemiBold"
                                                       Margin="0,14,0,0"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                            <ComboBox Margin="0,6,0,0" ItemsSource="{Binding ActionKinds}"
                                                      SelectedItem="{Binding BindKind, Mode=TwoWay}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Converter={StaticResource ActionKindLabel}}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>

                                            <!-- STEP 3: the contextual detail for the chosen action -->
                                            <TextBlock Margin="0,14,0,3" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       Text="{Binding BindTargetLabel, StringFormat='STEP 3 — {0}'}" />

                                            <!-- Launch / Open / Run: single line, with Browse for Launch -->
                                            <Grid Visibility="{Binding IsStandardTarget, Converter={StaticResource BoolToVis}}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ui:TextBox Grid.Column="0" PlaceholderText="{Binding BindTargetPlaceholder}"
                                                            Text="{Binding BindTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <ui:Button Grid.Column="1" Margin="8,0,0,0" Content="Browse…"
                                                           Click="BrowseButton_Click"
                                                           Visibility="{Binding ShowBrowse, Converter={StaticResource BoolToVis}}" />
                                            </Grid>

                                            <!-- Type text: multiline -->
                                            <ui:TextBox AcceptsReturn="True" TextWrapping="Wrap" MinHeight="64" MaxHeight="120"
                                                        VerticalScrollBarVisibility="Auto"
                                                        PlaceholderText="{Binding BindTargetPlaceholder}"
                                                        Text="{Binding BindTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        Visibility="{Binding IsMultilineTarget, Converter={StaticResource BoolToVis}}" />

                                            <!-- Hotkey: read-only recorder -->
                                            <ui:TextBox x:Name="HotkeyBox" IsReadOnly="True"
                                                        PlaceholderText="{Binding BindTargetPlaceholder}"
                                                        Text="{Binding BindTarget, Mode=OneWay}"
                                                        PreviewKeyDown="HotkeyBox_PreviewKeyDown" Cursor="Hand"
                                                        Visibility="{Binding IsHotkeyKind, Converter={StaticResource BoolToVis}}" />

                                            <!-- Media key: dropdown of media / volume actions -->
                                            <ComboBox Margin="0,8,0,0" ItemsSource="{Binding MediaOptions}"
                                                      DisplayMemberPath="Label" SelectedValuePath="Token"
                                                      SelectedValue="{Binding BindTarget, Mode=TwoWay}"
                                                      Visibility="{Binding IsMediaKind, Converter={StaticResource BoolToVis}}" />

                                            <!-- Layer switch: dropdown of the other layers -->
                                            <ComboBox Margin="0,8,0,0" ItemsSource="{Binding LayerTargets}"
                                                      SelectedItem="{Binding BindTarget, Mode=TwoWay}"
                                                      Visibility="{Binding ShowLayerPicker, Converter={StaticResource BoolToVis}}" />
                                            <TextBlock Margin="2,8,0,0" FontSize="12" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Text="Add another layer first with the + button above, then bind this key to switch to it."
                                                       Visibility="{Binding ShowAddLayerHint, Converter={StaticResource BoolToVis}}" />

                                            <!-- Arguments: only meaningful for Launch -->
                                            <ui:TextBox Margin="0,8,0,0" PlaceholderText="Arguments (optional)"
                                                        Text="{Binding BindArgs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        Visibility="{Binding ShowArguments, Converter={StaticResource BoolToVis}}" />

                                            <!-- Per-action help line -->
                                            <TextBlock Margin="2,8,0,0" FontSize="11" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       Text="{Binding BindTargetHelp}" />

                                            <ui:Button Margin="0,12,0,0" HorizontalAlignment="Stretch" Appearance="Primary"
                                                       Content="Add / update macro" Click="AddBindingButton_Click"
                                                       IsEnabled="{Binding HasBindKey}" />
                                        </StackPanel>
                                    </Border>

                                    <TextBlock DockPanel.Dock="Top" FontSize="11" FontWeight="SemiBold"
                                               Margin="2,0,0,8"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               Text="{Binding SelectedLayer.Name, StringFormat='KEYS ON “{0}”', TargetNullValue='BOUND KEYS'}" />
                                    <Grid>
                                        <TextBlock VerticalAlignment="Top" TextWrapping="Wrap" Margin="2,2,0,0"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   Visibility="{Binding Bindings.Count, Converter={StaticResource EmptyToVis}}"
                                                   Text="No macros bound yet." />
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding Bindings}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,0,6" Padding="10,8" CornerRadius="6" Background="#14FFFFFF">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Grid.Column="0">
                                                                    <TextBlock Text="{Binding KeyName}" FontWeight="SemiBold" />
                                                                    <TextBlock Text="{Binding Description}" FontSize="11" Margin="0,2,0,0"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                                </StackPanel>
                                                                <ui:Button Grid.Column="1" Content="✕" Appearance="Secondary"
                                                                           Padding="8,2" VerticalAlignment="Center"
                                                                           Click="RemoveBindingButton_Click" />
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- ABOUT VIEW -->
                    <Grid Margin="28,22,28,22" MaxWidth="660" HorizontalAlignment="Left"
                          Visibility="{Binding IsChecked, ElementName=NavAbout, Converter={StaticResource BoolToVis}}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="About" FontSize="26" FontWeight="Bold" Margin="0,0,0,4" />
                                <TextBlock Margin="0,0,0,14" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Text="Macrofy — isolate one keyboard and turn it into a macro pad, while your other keyboards keep working normally. Driver-free." />

                                <ui:Card Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="How capture works" FontWeight="SemiBold" Margin="0,0,0,6" />
                                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Text="Raw Input tells Macrofy which physical keyboard each keystroke came from. A global WH_KEYBOARD hook (a small native DLL) fires after Raw Input has already identified the device, so it can block ONLY the captured keyboard's keys and pass every other keyboard through untouched — no re-injection. No kernel driver, nothing installed system-wide, no anti-cheat footprint." />
                                    </StackPanel>
                                </ui:Card>

                                <ui:Card Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Macros" FontWeight="SemiBold" Margin="0,0,0,6" />
                                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Text="Capture a keyboard, press a key to select it, and bind it to an action — launch an app, open a URL, type text, send a hotkey, send a media/volume key, run a command, or switch layers. Layers let one key (held or toggled) flip the whole keyboard to a different set of macros. Bindings save per device as JSON and run on a background thread, so a slow launch never stalls capture." />
                                    </StackPanel>
                                </ui:Card>

                                <ui:Card>
                                    <StackPanel>
                                        <TextBlock Text="The phases" FontWeight="SemiBold" Margin="0,0,0,10" />

                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="✓ Phase 1 — Detection" FontWeight="SemiBold" Foreground="{StaticResource RmAccentBrush}" />
                                            <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,2,0,0"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Text="Enumerate every physical keyboard via Raw Input, group a device's HID collections together by VID/PID, and auto-name each from its HID product string." />
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="✓ Phase 2 — Isolation" FontWeight="SemiBold" Foreground="{StaticResource RmAccentBrush}" />
                                            <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,2,0,0"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Text="Block the captured keyboard's keys system-wide while leaving all other keyboards native. The in-process WH_KEYBOARD_LL hook turned out to be a dead end — blocking a key destroys the Raw Input needed to know its device — so this uses a global WH_KEYBOARD hook that decides after Raw Input." />
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="✓ Phase 3 — Macros" FontWeight="SemiBold" Foreground="{StaticResource RmAccentBrush}" />
                                            <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,2,0,0"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Text="Bind each captured key to an action (launch app, open URL, type text, send hotkey, run command), saved as per-device JSON profiles and executed off the input threads." />
                                        </StackPanel>

                                        <StackPanel>
                                            <TextBlock Text="• Phase 4 — Polish (in progress)"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" FontWeight="SemiBold" />
                                            <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,2,0,0"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       Text="Done: system tray + run-at-login, layers, and media keys. Still to come: multi-step macros and profile import/export." />
                                        </StackPanel>
                                    </StackPanel>
                                </ui:Card>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- BOTTOM STATUS BAR -->
        <Border Grid.Row="2" Background="{StaticResource RmSidebarBrush}" CornerRadius="12"
                Margin="8,8,8,8" Height="62">
            <Grid Margin="18,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="38" Height="38" CornerRadius="9" Background="{StaticResource RmCardBrush}">
                        <ui:SymbolIcon Symbol="Keyboard24" FontSize="18"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock FontWeight="SemiBold"
                                   Text="{Binding SelectedKeyboard.DisplayName, TargetNullValue='No device selected'}" />
                        <TextBlock FontSize="11" MaxWidth="640" TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   Text="{Binding StatusText}" />
                    </StackPanel>
                </StackPanel>

                <Border HorizontalAlignment="Right" VerticalAlignment="Center" CornerRadius="14" Padding="14,6">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#22FFFFFF" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCapturing}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource RmAccentBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Idle" />
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCapturing}" Value="True">
                                        <Setter Property="Text" Value="Capturing" />
                                        <Setter Property="Foreground" Value="#06201C" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
